{
  // https://nuxt.com/docs/guide/concepts/typescript
  "extends": "./.nuxt/tsconfig.json",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "types": ["nuxt"]
  },
  "include": [
    "app",
    "server",
    "content.config.ts",
    "nuxt.config.ts",
    "types/**/*.d.ts",
    "nuxt-content.d.ts"
  ],
  "exclude": ["node_modules", ".nuxt", ".output*", ".data", "dist"]
}
