{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Lint and Fix All Vue Files",
      "type": "shell",
      "command": "pnpm lint:fix",
      "problemMatcher": ["$eslint-stylish"]
    },
    {
      "label": "Lint and Fix Current Vue File",
      "type": "shell",
      "command": "pnpm eslint --fix ${file}",
      "problemMatcher": ["$eslint-stylish"],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}