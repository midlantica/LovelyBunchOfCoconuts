# Allow native/Rust build scripts needed by project dependencies.
# Limiting list (instead of '*') keeps security tighter while removing warning.
allow-build-scripts=@parcel/watcher,@tailwindcss/oxide,better-sqlite3,esbuild,unrs-resolver

# Ensure optional dependencies are installed (needed for oxc-parser native bindings)
optional=true

# Hoist packages to help with native module resolution in CI environments
shamefully-hoist=true

# Ensure peer dependencies are automatically installed
auto-install-peers=true
