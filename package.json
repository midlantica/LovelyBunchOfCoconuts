{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "scripts": {
    "check:new-memes": "node scripts/check-new-memes.js --no-fail",
    "check:new-memes:notify": "node scripts/check-new-memes.js --notify --no-fail",
    "watch:new-memes": "node scripts/watch-new-memes.js",
    "watch:new-memes:notify": "node scripts/watch-new-memes.js --notify",
    "watch:new-memes:auto": "node scripts/watch-new-memes.js --notify --auto",
    "watch:new-memes:auto:open": "node scripts/watch-new-memes.js --notify --auto --open-created",
    "build": "pnpm run regenerate-content && nuxt build",
    "dev": "nuxt dev",
    "dev:quiet": "SILENT_VITE=1 nuxt dev",
    "generate": "pnpm run regenerate-content && nuxt generate",
    "build:quiet": "SILENT_VITE=1 QUIET_BUILD=1 nuxt build",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "process-images": "node scripts/run-image-processing.js --open-created",
    "process-images:no-open": "node scripts/run-image-processing.js",
    "regenerate-content": "node scripts/regenerate-content-json.js",
    "update-ads": "node scripts/regenerate-content-json.js && echo 'Ads updated! Refresh your browser to see changes.'",
    "lint": "eslint . --ignore-pattern .tailwind-resolved.json",
    "lint:fix": "eslint . --fix --ignore-pattern .tailwind-resolved.json",
    "tw:config": "tailwindcss --show-config > .tailwind-resolved.json"
  },
  "scriptsExtra": {},
  "dependencies": {
    "@napi-rs/canvas": "^0.1.80",
    "@nuxt/content": "3.7.1",
    "@nuxt/eslint": "1.9.0",
    "@nuxt/icon": "2.0.0",
    "@nuxtjs/mdc": "0.17.4",
    "better-sqlite3": "12.4.1",
    "gray-matter": "^4.0.3",
    "lodash-es": "^4.17.21",
    "markdown-it": "^14.1.0",
    "nuxt": "^4.1.2",
    "vue": "^3.5.22",
    "vue-router": "^4.5.1"
  },
  "packageManager": "pnpm@10.15.1+sha512.34e538c329b5553014ca8e8f4535997f96180a1d0f614339357449935350d924e22f8614682191264ec33d1462ac21561aff97f6bb18065351c162c7e8f6de67",
  "devDependencies": {
    "@eslint/css": "^0.11.1",
    "@eslint/json": "^0.13.2",
    "@eslint/markdown": "^7.3.0",
    "@iconify-json/heroicons": "^1.2.3",
    "@iconify-json/heroicons-outline": "^1.2.1",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify-json/mdi-light": "^1.2.2",
    "@iconify-json/ri": "^1.2.5",
    "@iconify-json/simple-icons": "^1.2.53",
    "@nuxt/kit": "^4.1.2",
    "@nuxtjs/sitemap": "^7.4.7",
    "@tailwindcss/cli": "4.1.13",
    "@tailwindcss/postcss": "^4.1.13",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.13",
    "@typescript-eslint/parser": "^8.44.1",
    "eslint": "^9.36.0",
    "eslint-plugin-vue": "^10.5.0",
    "globals": "^16.4.0",
    "tailwindcss": "4.1.13"
  },
  "engines": {
    "node": ">=20.18.0 <23"
  }
}
