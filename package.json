{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "scripts": {
    "check:new-memes": "node scripts/check-new-memes.js --no-fail",
    "check:new-memes:notify": "node scripts/check-new-memes.js --notify --no-fail",
    "watch:new-memes": "node scripts/watch-new-memes.js",
    "watch:new-memes:notify": "node scripts/watch-new-memes.js --notify",
    "watch:new-memes:auto": "node scripts/watch-new-memes.js --notify --auto",
    "watch:new-memes:auto:open": "node scripts/watch-new-memes.js --notify --auto --open-created",
    "build": "pnpm run validate-frontmatter:strict && pnpm run regenerate-content && nuxt build",
    "dev": "pnpm run validate-frontmatter && pnpm run regenerate-content && nuxt dev",
    "dev:quiet": "SILENT_VITE=1 nuxt dev",
    "generate": "pnpm run regenerate-content && nuxt generate",
    "build:quiet": "SILENT_VITE=1 QUIET_BUILD=1 nuxt build",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "process-images": "node scripts/run-image-processing.js --open-created",
    "process-images:no-open": "node scripts/run-image-processing.js",
    "regenerate-content": "node scripts/regenerate-content-json.js",
    "validate-frontmatter": "node scripts/validate-frontmatter.js",
    "validate-frontmatter:strict": "node scripts/validate-frontmatter.js --exit-on-error",
    "update-ads": "node scripts/regenerate-content-json.js && echo 'Ads updated! Refresh your browser to see changes.'",
    "lint": "eslint . --ignore-pattern .tailwind-resolved.json",
    "lint:fix": "eslint . --fix --ignore-pattern .tailwind-resolved.json",
    "tw:config": "tailwindcss --show-config > .tailwind-resolved.json"
  },
  "scriptsExtra": {},
  "dependencies": {
    "@napi-rs/canvas": "^0.1.81",
    "@netlify/blobs": "^10.3.3",
    "@nuxt/content": "3.8.0",
    "@nuxt/eslint": "1.10.0",
    "@nuxt/icon": "2.1.0",
    "@nuxtjs/mdc": "0.18.2",
    "gray-matter": "^4.0.3",
    "markdown-it": "^14.1.0",
    "nuxt": "^4.2.1",
    "vue": "^3.5.24",
    "vue-router": "^4.6.3"
  },
  "packageManager": "pnpm@10.20.0+sha512.cf9998222162dd85864d0a8102e7892e7ba4ceadebbf5a31f9c2fce48dfce317a9c53b9f6464d1ef9042cba2e02ae02a9f7c143a2b438cd93c91840f0192b9dd",
  "devDependencies": {
    "@eslint/css": "^0.14.1",
    "@eslint/json": "^0.14.0",
    "@eslint/markdown": "^7.5.1",
    "@iconify-json/bitcoin-icons": "^1.2.4",
    "@iconify-json/heroicons": "^1.2.3",
    "@iconify-json/heroicons-outline": "^1.2.1",
    "@iconify-json/lucide": "^1.2.73",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify-json/mdi-light": "^1.2.2",
    "@iconify-json/mingcute": "^1.2.5",
    "@iconify-json/ri": "^1.2.6",
    "@iconify-json/simple-icons": "^1.2.58",
    "@iconify-json/streamline-logos": "^1.2.0",
    "@iconify-json/svg-spinners": "^1.2.4",
    "@iconify-json/tabler": "^1.2.23",
    "@nuxt/kit": "^4.2.1",
    "@nuxtjs/sitemap": "^7.4.7",
    "@oxc-minify/binding-linux-x64-gnu": "0.96.0",
    "@oxc-parser/binding-linux-x64-gnu": "0.96.0",
    "@oxc-transform/binding-linux-x64-gnu": "0.96.0",
    "@tailwindcss/cli": "4.1.17",
    "@tailwindcss/postcss": "^4.1.17",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.17",
    "@typescript-eslint/parser": "^8.46.4",
    "eslint": "^9.39.1",
    "eslint-plugin-vue": "^10.5.1",
    "globals": "^16.5.0",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "sharp": "^0.34.5",
    "tailwindcss": "4.1.17",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=20.18.0 <23"
  }
}
