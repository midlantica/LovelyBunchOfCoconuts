{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "scripts": {
    "check:new-memes": "node scripts/check-new-memes.js --no-fail",
    "check:new-memes:notify": "node scripts/check-new-memes.js --notify --no-fail",
    "watch:new-memes": "node scripts/watch-new-memes.js",
    "watch:new-memes:notify": "node scripts/watch-new-memes.js --notify",
    "watch:new-memes:auto": "node scripts/watch-new-memes.js --notify --auto",
    "watch:new-memes:auto:open": "node scripts/watch-new-memes.js --notify --auto --open-created",
    "build": "pnpm run validate-frontmatter:strict && pnpm run regenerate-content && nuxt build",
    "dev": "pnpm run validate-frontmatter && pnpm run regenerate-content && nuxt dev",
    "dev:quiet": "SILENT_VITE=1 nuxt dev",
    "generate": "pnpm run regenerate-content && nuxt generate",
    "build:quiet": "SILENT_VITE=1 QUIET_BUILD=1 nuxt build",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "process-images": "node scripts/run-image-processing.js --open-created",
    "process-images:no-open": "node scripts/run-image-processing.js",
    "regenerate-content": "node scripts/regenerate-content-json.js",
    "validate-frontmatter": "node scripts/validate-frontmatter.js",
    "validate-frontmatter:strict": "node scripts/validate-frontmatter.js --exit-on-error",
    "update-ads": "node scripts/regenerate-content-json.js && echo 'Ads updated! Refresh your browser to see changes.'",
    "lint": "eslint . --ignore-pattern .tailwind-resolved.json",
    "lint:fix": "eslint . --fix --ignore-pattern .tailwind-resolved.json",
    "tw:config": "tailwindcss --show-config > .tailwind-resolved.json"
  },
  "scriptsExtra": {},
  "dependencies": {
    "@napi-rs/canvas": "^0.1.96",
    "@netlify/blobs": "^10.7.2",
    "@netlify/nuxt": "0.2.34",
    "@nuxt/content": "3.12.0",
    "@nuxt/eslint": "1.15.2",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/icon": "^2.1.1",
    "@nuxt/image": "^2.0.0",
    "@nuxtjs/mdc": "^0.20.2",
    "gray-matter": "^4.0.3",
    "markdown-it": "^14.1.1",
    "nuxt": "4.4.2",
    "vue": "^3.5.30",
    "vue-router": "^4.6.4"
  },
  "packageManager": "pnpm@10.28.1+sha512.7d7dbbca9e99447b7c3bf7a73286afaaf6be99251eb9498baefa7d406892f67b879adb3a1d7e687fc4ccc1a388c7175fbaae567a26ab44d1067b54fcb0d6a316",
  "devDependencies": {
    "@eslint/css": "^0.14.1",
    "@eslint/json": "^0.14.0",
    "@eslint/markdown": "^7.5.1",
    "@nuxt/kit": "4.4.2",
    "@nuxtjs/sitemap": "7.6.0",
    "@oxc-minify/binding-linux-x64-gnu": "0.115.0",
    "@oxc-parser/binding-linux-x64-gnu": "0.115.0",
    "@oxc-transform/binding-linux-x64-gnu": "0.115.0",
    "@shikijs/engine-javascript": "^3.22.0",
    "@shikijs/engine-oniguruma": "^3.22.0",
    "@tailwindcss/cli": "4.2.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.1",
    "@typescript-eslint/parser": "^8.57.0",
    "baseline-browser-mapping": "^2.10.7",
    "eslint": "^9.39.2",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "sharp": "^0.34.5",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vite-plugin-vue-mcp": "^0.3.2"
  },
  "engines": {
    "node": ">=20.18.0 <23"
  }
}
